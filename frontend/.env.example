# Backend Services Configuration
# Make sure to start these services separately before running the frontend

# Express.js Backend (User management, authentication)
VITE_API_URL=http://localhost:3000

# WebSocket for real-time updates
VITE_WS_URL=ws://localhost:3000

# FastAPI Wris Flood Model (Flood predictions for 85 Indian districts)
# START THIS: python Wris_flood_model/run.py
VITE_WRIS_URL=http://localhost:8000

# FastAPI ML Backend (AQI analysis, safe flood routing)
# START THIS: python main.py (or: uvicorn main:app --reload --port 8001 if Wris uses 8000)
# NOTE: If Wris model runs on port 8000, configure this to port 8001:
#       Option 1: Update VITE_ML_URL to http://localhost:8001
#       Option 2: Run: PORT=8001 python main.py
VITE_ML_URL=http://localhost:8000
