# GeoAware ML API - Environment Variables
# Copy this file to .env and fill in your values for local development
# On Render, set these directly in the dashboard (Settings > Environment Variables)

# URL of the Mosdac ML model service (3rd backend)
# Local: http://127.0.0.1:8001
# Production: https://your-mosdac-service.onrender.com
MOSDAC_URL=http://127.0.0.1:8001
